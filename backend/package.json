{
  "name": "backend",
  "scripts": {
    "predev": "lsof -ti :5001 | xargs kill -9 2>/dev/null; exit 0",
    "dev": "ts-node-dev --exit-child --respawn --transpile-only src/server.ts",
    "build": "tsc --outDir dist --rootDir src",
    "start": "node dist/server.js",
    "test": "jest --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": { "module": "commonjs" } }]
    }
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.6.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
